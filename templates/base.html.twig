<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ 'base.title'|trans }}{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}?v=20260411-1">
        <link rel="stylesheet" href="{{ asset('styles/dark-theme.css') }}?v=20260407-2">
        {% if app.request.attributes.get('_route') starts with 'admin_' %}
            <link rel="stylesheet" href="{{ asset('styles/admin.css') }}?v=20260407-1">
        {% endif %}
        {% if app.environment == 'prod' %}
            <link rel="icon" type="image/png" sizes="64x64" href="{{ asset('favicon.ico') }}?v=20260407-1">
        {% else %}
            <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%2292%22>₾</text></svg>">
        {% endif %}
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
        {% if app.user %}
            <meta name="data-authenticated" content="true">
            {% set user_prefs = user_preferences() %}
            <script>
                // Apply user preferences from database on page load
                (function() {
                    const userPreferences = {{ user_prefs|json_encode|raw }};

                    // Apply theme from database
                    if (userPreferences.theme) {
                        try {
                            localStorage.setItem('spending-plan-theme', userPreferences.theme);
                        } catch (e) {}
                        document.cookie = '_theme=' + userPreferences.theme + '; path=/; max-age=' + (365 * 24 * 60 * 60) + '; SameSite=Lax';
                        document.documentElement.setAttribute('data-theme', userPreferences.theme);
                    }

                    // Apply language from database - redirect if different from current
                    if (userPreferences.language && userPreferences.language !== '{{ app.request.locale }}') {
                        // Add _locale query parameter to current URL
                        const url = new URL(window.location.href);
                        url.searchParams.set('_locale', userPreferences.language);
                        window.location.replace(url.toString());
                    }
                })();
            </script>
        {% endif %}
    </head>
    <body {% if app.user %}data-authenticated{% endif %}>
        {% set globalPopup = is_granted('ROLE_ADMIN') ? admin_popup() : {show: false, title: '', message: '', monthKey: '', template: '', actions: []} %}
        <header class="site-nav">
            <div class="nav-shell">
                <a class="brand" href="{{ path('web_home') }}">{{ 'base.brand'|trans }}</a>
                <nav class="nav-links">
                    <a href="{{ path('web_home') }}">{{ 'nav.home'|trans }}</a>
                    {% if app.user %}
                        <a href="{{ path('app_dashboard') }}">{{ 'nav.dashboard'|trans }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}">{{ 'nav.admin'|trans }}</a>
                        {% endif %}
                        <form method="post" action="{{ path('app_logout') }}" style="display:inline;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button type="submit" class="btn-ghost">
                                {{ 'nav.logout'|trans({'%user%': app.user.userIdentifier}) }}
                            </button>
                        </form>
                    {% else %}
                        <a href="{{ path('app_login') }}">{{ 'nav.login'|trans }}</a>
                    {% endif %}
                    {# Language and theme switchers are now handled by React in migrated pages #}
                    <div id="react-header-switchers" data-react-header></div>
                </nav>
            </div>
        </header>

        <section class="page">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }} reveal">
                        <strong>{{ ('flash.' ~ label)|trans }}</strong> {{ message|trans }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </section>

        {% if globalPopup.show %}
            <aside class="sp-popup" data-sp-popup>
                <button type="button" class="sp-popup-close" data-sp-popup-close aria-label="{{ 'base.close'|trans }}">×</button>
                <h3>{{ globalPopup.title }}</h3>
                <p>{{ globalPopup.message }}</p>
                {% if globalPopup.actions is iterable and globalPopup.actions|length > 0 %}
                    <div class="actions sp-popup-actions">
                        {% for action in globalPopup.actions %}
                            <form method="post" action="{{ path('admin_notifications_action') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_notification_action') }}">
                                <input type="hidden" name="template" value="{{ globalPopup.template }}">
                                <input type="hidden" name="monthKey" value="{{ globalPopup.monthKey }}">
                                <input type="hidden" name="action" value="{{ action.code|default('') }}">
                                <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
                                <button type="submit" class="{{ (action.code|default('')) == 'remind_later' ? 'btn-ghost' : 'btn' }}">
                                    {{ action.label|default('Action') }}
                                </button>
                            </form>
                        {% endfor %}
                    </div>
                {% elseif globalPopup.monthKey is not empty %}
                    <a class="btn" href="{{ path('admin_spending_plans_index', {month: globalPopup.monthKey}) }}">
                        {{ 'admin.spending_plans.open'|trans }}
                    </a>
                {% endif %}
            </aside>
            <script>
                (() => {
                    const popup = document.querySelector('[data-sp-popup]');
                    if (!popup) {
                        return;
                    }
                    const closeBtn = popup.querySelector('[data-sp-popup-close]');
                    closeBtn?.addEventListener('click', () => {
                        popup.classList.add('is-hidden');
                        window.setTimeout(() => popup.remove(), 220);
                    });
                })();
            </script>
        {% endif %}
        <script src="{{ asset('js/form-validation-popup.js') }}"></script>
        {# React header switchers for pages still using Twig #}
        <script type="module" src="{{ asset('spa/header-switchers.js') }}"></script>
        {# pill-toggle.js and theme-toggle.js removed - now handled by React #}
    </body>
</html>
