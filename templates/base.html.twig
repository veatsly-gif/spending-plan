<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Spending Plan{% endblock %}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%2292%22>₾</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% endblock %}
    </head>
    <body>
        {% set globalPopup = is_granted('ROLE_ADMIN') ? admin_popup() : {show: false, title: '', message: '', monthKey: ''} %}
        <header class="site-nav">
            <div class="nav-shell">
                <a class="brand" href="{{ path('web_home') }}">Spending Plan</a>
                <nav class="nav-links">
                    <a href="{{ path('web_home') }}">Home</a>
                    {% if app.user %}
                        <a href="{{ path('app_dashboard') }}">Dashboard</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin_dashboard') }}">Admin</a>
                        {% endif %}
                        <form method="post" action="{{ path('app_logout') }}" style="display:inline;">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button type="submit" class="btn-ghost">Logout {{ app.user.userIdentifier }}</button>
                        </form>
                    {% else %}
                        <a href="{{ path('app_login') }}">Login</a>
                    {% endif %}
                </nav>
            </div>
        </header>

        <section class="page">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash-{{ label }} reveal">
                        <strong>{{ label|upper }}</strong> {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </section>

        {% if globalPopup.show %}
            <aside class="sp-popup" data-sp-popup>
                <button type="button" class="sp-popup-close" data-sp-popup-close aria-label="Close">×</button>
                <h3>{{ globalPopup.title }}</h3>
                <p>{{ globalPopup.message }}</p>
                <a class="btn" href="{{ path('admin_spending_plans_index', {month: globalPopup.monthKey}) }}">
                    Open Spending Plans
                </a>
            </aside>
            <script>
                (() => {
                    const popup = document.querySelector('[data-sp-popup]');
                    if (!popup) {
                        return;
                    }
                    const closeBtn = popup.querySelector('[data-sp-popup-close]');
                    closeBtn?.addEventListener('click', () => {
                        popup.classList.add('is-hidden');
                        window.setTimeout(() => popup.remove(), 220);
                    });
                })();
            </script>
        {% endif %}
    </body>
</html>
