{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'spends.title'|trans }}{% endblock %}

{% block body %}
    {% set query = app.request.query.all %}

    <main class="panel reveal panel-with-corner-action">
        <div class="panel-head-inline">
            <span class="kicker">{{ 'spends.kicker'|trans }}</span>
            <a class="btn btn-ghost panel-corner-action" href="{{ path('app_dashboard') }}">{{ 'common.back_to_dashboard'|trans }}</a>
        </div>
        <h1>{{ 'spends.heading'|trans({'%month%': monthLabel}) }}</h1>

        <div class="actions" style="margin-top: 10px;">
            <a
                class="sp-tab {{ viewMode == 'stream' ? 'is-active' : '' }}"
                href="{{ path('app_dashboard_spends', query|merge({view: 'stream', page: 1})) }}"
            >
                {{ 'spends.view.stream'|trans }}
            </a>
            <a
                class="sp-tab {{ viewMode == 'table' ? 'is-active' : '' }}"
                href="{{ path('app_dashboard_spends', query|merge({view: 'table', page: 1})) }}"
            >
                {{ 'spends.view.table'|trans }}
            </a>
        </div>

        <nav class="sp-tabs" aria-label="{{ 'spends.month_tabs'|trans }}">
            {% for tab in monthTabs %}
                <a
                    href="{{ path('app_dashboard_spends', query|merge({month: tab.monthKey, page: 1})) }}"
                    class="sp-tab {{ tab.active ? 'is-active' : '' }}"
                >
                    {{ tab.label }}
                </a>
            {% endfor %}
        </nav>

        <section class="spend-filters" style="margin-top: 14px;">
            <h2 class="spend-filters-title">{{ 'spends.filters.title'|trans }}</h2>
            <form method="get" action="{{ path('app_dashboard_spends') }}" class="spend-filter-grid">
                <input type="hidden" name="month" value="{{ selectedMonthKey }}">
                <input type="hidden" name="sort" value="{{ sort }}">
                <input type="hidden" name="dir" value="{{ dir }}">
                <input type="hidden" name="view" value="{{ viewMode }}">

                <div class="spend-filter-field spend-filter-currency">
                    <label for="currency">{{ 'common.currency'|trans }}</label>
                    <select id="currency" name="currency">
                        <option value="">{{ 'common.all'|trans }}</option>
                        {% for code in availableCurrencies %}
                            <option value="{{ code }}" {{ code == filterCurrency ? 'selected' : '' }}>{{ code }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="spend-filter-field spend-filter-user">
                    <label for="user">{{ 'common.user'|trans }}</label>
                    <select id="user" name="user">
                        <option value="">{{ 'common.all'|trans }}</option>
                        {% for username in availableUsers %}
                            <option value="{{ username }}" {{ username == filterUser ? 'selected' : '' }}>{{ username }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="spend-filter-field spend-filter-plan">
                    <label for="plan">{{ 'common.spending_plan'|trans }}</label>
                    <select id="plan" name="plan">
                        <option value="">{{ 'common.all'|trans }}</option>
                        {% for plan in availablePlans %}
                            <option value="{{ plan.id }}" {{ (plan.id ~ '') == filterPlanId ? 'selected' : '' }}>
                                {{ plan.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="spend-filter-field spend-filter-search">
                    <label for="q">{{ 'common.search'|trans }}</label>
                    <input id="q" name="q" value="{{ filterQuery }}" placeholder="{{ 'spends.filters.search_placeholder'|trans }}">
                </div>

                <div class="spend-filter-field spend-filter-per-page">
                    <label for="perPage">{{ 'spends.filters.rows_per_page'|trans }}</label>
                    <select id="perPage" name="perPage">
                        {% for option in perPageOptions %}
                            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="actions spend-filter-actions">
                    <button type="submit">{{ 'common.apply'|trans }}</button>
                    <a
                        class="btn btn-ghost"
                        href="{{ path('app_dashboard_spends', {month: selectedMonthKey, sort: sort, dir: dir, perPage: perPage, view: viewMode}) }}"
                    >
                        {{ 'spends.filters.reset'|trans }}
                    </a>
                </div>
            </form>
        </section>

        {% if spends is empty %}
            <div class="empty" style="margin-top: 14px;">
                <strong>{{ 'spends.empty'|trans }}</strong>
            </div>
        {% else %}
            {% if viewMode == 'stream' %}
                <section class="spend-stream" style="margin-top: 14px;">
                    {% for group in streamGroups %}
                        <details class="spend-stream-group" {{ group.expanded ? 'open' : '' }}>
                            <summary class="spend-stream-summary">
                                <div class="spend-stream-summary-inner">
                                    <span class="spend-stream-title">
                                        {{ group.name }}
                                        {% if group.current %}
                                            <span class="badge">{{ 'spends.stream.current_plan'|trans }}</span>
                                        {% endif %}
                                    </span>
                                    <span class="spend-stream-meta">
                                        <span>{{ 'spends.stream.spent'|trans }}: <strong>{{ group.totalAmountLabel }}</strong></span>
                                        <span>{{ 'spends.stream.planned'|trans }}: <strong>{{ group.plannedAmountLabel }}</strong></span>
                                    </span>
                                </div>
                                <span class="spend-stream-chevron" aria-hidden="true"></span>
                            </summary>
                            <div class="spend-stream-body">
                                {% if group.spends is empty %}
                                    <p class="spend-stream-empty">{{ 'spends.stream.no_spends_in_plan'|trans }}</p>
                                {% else %}
                                    {% for spend in group.spends %}
                                        <article class="spend-stream-item">
                                            <div class="spend-stream-item-inner">
                                                <div class="spend-stream-item-line">
                                                    <span class="spend-stream-item-field is-amount">{{ spend.amount }} {{ spend.currencyCode }}</span>
                                                    <span class="spend-stream-item-field is-comment">{{ spend.comment ?? '-' }}</span>
                                                    <span class="spend-stream-item-field is-datetime">{{ spend.createdAtLabel }}</span>
                                                    <span class="spend-stream-item-field is-author">{{ spend.username }}</span>
                                                </div>
                                                {% include 'components/_row_actions_edit_delete.html.twig' with {
                                                    editHref: path('app_dashboard_spends_edit', {id: spend.id}),
                                                    deleteAction: path('app_dashboard_spends_delete', {id: spend.id}),
                                                    csrfToken: csrf_token('delete_spend_' ~ spend.id),
                                                    deleteConfirm: 'spend.confirm_delete'|trans,
                                                    rowActionsClass: 'spend-stream-item-actions'
                                                } %}
                                            </div>
                                        </article>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </details>
                    {% endfor %}
                </section>
            {% else %}
                <div class="table-wrap" style="margin-top: 14px;">
                    <table>
                        <thead>
                            <tr>
                                {% set nextDir = sort == 'spendDate' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'spendDate', dir: nextDir, page: 1})) }}">{{ 'spends.table.spend_date'|trans }}</a></th>

                                {% set nextDir = sort == 'username' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'username', dir: nextDir, page: 1})) }}">{{ 'common.user'|trans }}</a></th>

                                {% set nextDir = sort == 'amount' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'amount', dir: nextDir, page: 1})) }}">{{ 'common.amount'|trans }}</a></th>

                                {% set nextDir = sort == 'currency' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'currency', dir: nextDir, page: 1})) }}">{{ 'common.currency'|trans }}</a></th>

                                {% set nextDir = sort == 'spendingPlan' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'spendingPlan', dir: nextDir, page: 1})) }}">{{ 'common.plan'|trans }}</a></th>

                                <th>{{ 'common.comment'|trans }}</th>

                                {% set nextDir = sort == 'createdAt' and dir == 'asc' ? 'desc' : 'asc' %}
                                <th><a href="{{ path('app_dashboard_spends', query|merge({sort: 'createdAt', dir: nextDir, page: 1})) }}">{{ 'spends.table.added_at'|trans }}</a></th>
                                <th>{{ 'common.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for spend in spends %}
                                <tr>
                                    <td>{{ spend.spendDateLabel }}</td>
                                    <td>{{ spend.username }}</td>
                                    <td>{{ spend.amount }}</td>
                                    <td>{{ spend.currencyCode }}</td>
                                    <td>{{ spend.spendingPlanName }}</td>
                                    <td>{{ spend.comment ?? '-' }}</td>
                                    <td>{{ spend.createdAtLabel }}</td>
                                    <td class="table-row-actions-cell">
                                        {% include 'components/_row_actions_edit_delete.html.twig' with {
                                            editHref: path('app_dashboard_spends_edit', {id: spend.id}),
                                            deleteAction: path('app_dashboard_spends_delete', {id: spend.id}),
                                            csrfToken: csrf_token('delete_spend_' ~ spend.id),
                                            deleteConfirm: 'spend.confirm_delete'|trans
                                        } %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            <div class="grid metrics" style="margin-top: 14px;">
                <article class="metric">
                    <h3>{{ 'spends.total_records'|trans }}</h3>
                    <p>{{ totalRecords }}</p>
                </article>
                <article class="metric">
                    <h3>{{ 'spends.total_amount'|trans }}</h3>
                    <p>{{ totalAmountLabel }}</p>
                </article>
            </div>

            {% if viewMode == 'table' and totalPages > 1 %}
                <nav class="pagination" aria-label="{{ 'spends.pagination'|trans }}">
                    <a
                        class="btn btn-ghost {{ page <= 1 ? 'is-disabled' : '' }}"
                        href="{{ path('app_dashboard_spends', query|merge({page: page - 1})) }}"
                    >
                        {{ 'common.prev'|trans }}
                    </a>

                    {% for pageNo in 1..totalPages %}
                        <a
                            class="btn btn-ghost {{ pageNo == page ? 'is-active' : '' }}"
                            href="{{ path('app_dashboard_spends', query|merge({page: pageNo})) }}"
                        >
                            {{ pageNo }}
                        </a>
                    {% endfor %}

                    <a
                        class="btn btn-ghost {{ page >= totalPages ? 'is-disabled' : '' }}"
                        href="{{ path('app_dashboard_spends', query|merge({page: page + 1})) }}"
                    >
                        {{ 'common.next'|trans }}
                    </a>
                </nav>
            {% endif %}
        {% endif %}
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.dashboardSpendsPage = {
            month: {{ selectedMonthKey|json_encode|raw }},
            versionUrl: {{ path('app_dashboard_spends_version')|json_encode|raw }},
            updateMessage: {{ 'spends.live_update'|trans|json_encode|raw }}
        };
    </script>
    <script src="{{ asset('js/dashboard-spends-live.js') }}"></script>
{% endblock %}
