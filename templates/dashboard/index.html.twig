{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'dashboard.title'|trans }}{% endblock %}

{% block body %}
    <main class="panel reveal">
        <div class="dash-top-row">
            <span class="kicker">{{ 'dashboard.kicker'|trans }}</span>
            <div class="dash-rates-row reveal delay">
                <span class="dash-rate-pill">{{ 'dashboard.eur_gel'|trans }}: <strong>{{ incomeWidget.eurGelRate ?? ('common.na'|trans) }}</strong></span>
                <span class="dash-rate-pill">{{ 'dashboard.usdt_gel'|trans }}: <strong>{{ incomeWidget.usdtGelRate ?? ('common.na'|trans) }}</strong></span>
            </div>
        </div>
{#        <h1>{{ 'dashboard.heading'|trans }}</h1>#}
{#        <p>{{ 'dashboard.description'|trans }}</p>#}

        <section class="grid dashboard-double-grid">
            <article class="metric reveal delay spend-widget dashboard-main-card" data-spend-widget>
                <h3>{{ 'dashboard.spends_for_month'|trans({'%month%': spendWidget.monthLabel}) }}</h3>
                <div class="dash-progress-head">
                    <div>
                        <p class="subtle">{{ 'dashboard.month_spent'|trans }}</p>
                        <p class="dash-big" data-spend-widget-month>{{ spendWidget.monthSpentGel }} GEL</p>
                    </div>
                    <div class="dash-progress-side">
                        <p class="subtle">{{ 'dashboard.month_limit'|trans }}</p>
                        <p class="dash-big" data-spend-widget-limit>{{ spendWidget.monthLimitGel }} GEL</p>
                    </div>
                </div>
                <div class="dash-progress-track">
                    <span
                        class="dash-progress-fill is-{{ spendWidget.monthSpendProgressTone }}"
                        style="--progress-target: {{ spendWidget.monthSpendProgressBarPercent }}%; width: {{ spendWidget.monthSpendProgressBarPercent }}%;"
                        data-spend-widget-progress-bar
                    ></span>
                </div>
                <p class="subtle">
                    {{ 'dashboard.progress_to_limit'|trans }}:
                    <strong data-spend-widget-progress-text>{{ spendWidget.monthSpendProgressPercent }}%</strong>
                </p>

                <div class="dash-today-row">
                    <span>{{ 'dashboard.spends_today'|trans }}</span>
                    <strong data-spend-widget-today>{{ spendWidget.todaySpentGel }} GEL</strong>
                </div>

                <div class="table-wrap dash-recent-table">
                    <table>
                        <thead>
                            <tr>
                                <th>{{ 'dashboard.table.amount'|trans }}</th>
                                <th>{{ 'dashboard.table.datetime'|trans }}</th>
                                <th>{{ 'dashboard.table.user'|trans }}</th>
                                <th>{{ 'dashboard.table.description'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody data-spend-widget-recent>
                            {% for spend in spendWidget.recentSpends %}
                                <tr>
                                    <td>{{ spend.amount }} {{ spend.currencyCode }}</td>
                                    <td>{{ spend.createdAtLabel }}</td>
                                    <td>{{ spend.username }}</td>
                                    <td>{{ spend.comment ?: ('common.na'|trans) }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4">{{ 'dashboard.no_spends_yet'|trans }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div class="actions" style="margin-top: 8px;">
                    <a class="btn btn-ghost" href="{{ path('app_dashboard_spends') }}">
                        {{ 'dashboard.open_spends'|trans }}
                    </a>
                </div>
            </article>

            <article class="metric reveal delay dashboard-main-card">
                <h3>{{ 'dashboard.income_for_month'|trans({'%month%': incomeWidget.monthLabel}) }}</h3>
                <div class="dash-income-row">
                    <span>{{ 'dashboard.total_income_gel'|trans }}</span>
                    <strong>{{ incomeWidget.totalIncomeGel }} GEL</strong>
                </div>
                <div class="dash-income-row">
                    <span>{{ 'dashboard.available_to_spend'|trans }}</span>
                    <strong>{{ incomeWidget.availableToSpendGel }} GEL</strong>
                </div>
                <p class="subtle">
                    {{ 'dashboard.regular_planned_total'|trans({'%amount%': incomeWidget.regularAndPlannedGel}) }}
                </p>
                <p class="subtle">{{ 'dashboard.updated'|trans }}: {{ incomeWidget.ratesUpdatedAtLabel ?? ('common.na'|trans) }}</p>
                <div class="actions" style="margin-top: 8px;">
                    <a class="btn btn-ghost" href="{{ path('app_dashboard_incomes') }}">
                        {{ 'dashboard.open_incomes'|trans }}
                    </a>
                    {% if incomeForm is defined %}
                        <a class="btn" href="#" data-income-modal-open>
                            {{ 'dashboard.add_income_button'|trans }}
                        </a>
                    {% endif %}
                </div>
            </article>
        </section>
    </main>

    {% if spendForm is defined %}
        <section class="panel reveal delay" style="margin-top: 16px;">
            <span class="kicker">{{ 'dashboard.spend'|trans }}</span>
            <h2>{{ 'dashboard.add_spend'|trans }}</h2>
            <p class="form-status" data-spend-feedback hidden></p>
            {{ form_start(spendForm, {'attr': {'data-spend-form': '1'}}) }}
                {{ form_row(spendForm.amount) }}
                {{ form_row(spendForm.currency) }}
                {{ form_row(spendForm.spendingPlan) }}
                {{ form_row(spendForm.spendDate) }}
                {{ form_row(spendForm.comment) }}
                <div class="actions">
                    <button type="submit" data-spend-submit>{{ 'dashboard.add_spend_button'|trans }}</button>
                </div>
            {{ form_end(spendForm) }}
        </section>
    {% endif %}

    {% if incomeForm is defined %}
        {% include 'dashboard/_income_modal.html.twig' with {incomeForm: incomeForm} %}
    {% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.dashboardSpendFormI18n = {
            saving: {{ 'spend.js.saving'|trans|json_encode|raw }},
            unableAdd: {{ 'spend.js.unable_add'|trans|json_encode|raw }},
            networkError: {{ 'spend.js.network_error'|trans|json_encode|raw }},
            addSpend: {{ 'dashboard.add_spend_button'|trans|json_encode|raw }},
            adding: {{ 'spend.js.adding'|trans|json_encode|raw }},
            added: {{ 'spend.js.added'|trans|json_encode|raw }},
            saved: {{ 'spend.js.saved'|trans|json_encode|raw }}
        };
        window.dashboardIncomeFormI18n = {
            saving: {{ 'income.js.saving'|trans|json_encode|raw }},
            unableAdd: {{ 'income.js.unable_add'|trans|json_encode|raw }},
            networkError: {{ 'income.js.network_error'|trans|json_encode|raw }},
            addIncome: {{ 'dashboard.add_income_button'|trans|json_encode|raw }},
            adding: {{ 'income.js.adding'|trans|json_encode|raw }},
            added: {{ 'income.js.added'|trans|json_encode|raw }}
        };
    </script>
    <script src="{{ asset('js/dashboard-spend-form.js') }}"></script>
    <script src="{{ asset('js/dashboard-income-modal.js') }}"></script>
{% endblock %}
