{% trans_default_domain 'messages' %}

<div class="sp-modal" data-income-modal hidden>
    <div class="sp-modal-card" role="dialog" aria-modal="true" aria-labelledby="income-modal-title">
        <div class="sp-modal-head">
            <h2 id="income-modal-title">{{ 'dashboard.add_income'|trans }}</h2>
            <button type="button" class="sp-modal-close" data-income-modal-close aria-label="{{ 'base.close'|trans }}">×</button>
        </div>
        <p class="form-status" data-income-feedback hidden></p>
        {{ form_start(incomeForm, {'attr': {'data-income-form': '1'}}) }}
            <input type="hidden" name="_redirect" value="{{ app.request.requestUri }}">
            {{ form_row(incomeForm.amount) }}
            {{ form_row(incomeForm.currency) }}
            {{ form_row(incomeForm.comment) }}
            {{ form_row(incomeForm.convertToGel) }}
            <div class="actions">
                <button type="submit" data-income-submit>{{ 'dashboard.add_income_button'|trans }}</button>
            </div>
        {{ form_end(incomeForm) }}
    </div>
</div>
