{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'incomes.title'|trans }}{% endblock %}

{% block body %}
    {% set query = app.request.query.all %}

    <main class="panel reveal">
        <span class="kicker">{{ 'incomes.kicker'|trans }}</span>
        <h1>{{ 'incomes.heading'|trans({'%month%': monthLabel}) }}</h1>

        <div class="actions" style="margin-top: 10px;">
            <a class="btn btn-ghost" href="{{ path('app_dashboard') }}">{{ 'common.back_to_dashboard'|trans }}</a>
            {% if incomeForm is defined %}
                <a class="btn" href="#" data-income-modal-open>
                    {{ 'dashboard.add_income_button'|trans }}
                </a>
            {% endif %}
            <a
                class="btn btn-ghost"
                href="{{ path('app_dashboard_incomes', query|merge({month: previousMonthKey, page: 1})) }}"
            >
                {{ 'incomes.previous_month'|trans({'%month%': previousMonthKey}) }}
            </a>
            <a
                class="btn btn-ghost"
                href="{{ path('app_dashboard_incomes', query|merge({month: nextMonthKey, page: 1})) }}"
            >
                {{ 'incomes.next_month'|trans({'%month%': nextMonthKey}) }}
            </a>
        </div>

        <nav class="sp-tabs" aria-label="{{ 'incomes.month_tabs'|trans }}">
            {% for tab in monthTabs %}
                <a
                    href="{{ path('app_dashboard_incomes', query|merge({month: tab.monthKey, page: 1})) }}"
                    class="sp-tab {{ tab.active ? 'is-active' : '' }}"
                >
                    {{ tab.label }}
                </a>
            {% endfor %}
        </nav>

        <section class="spend-filters" style="margin-top: 14px;">
            <h2 class="spend-filters-title">{{ 'incomes.filters.title'|trans }}</h2>
            <form method="get" action="{{ path('app_dashboard_incomes') }}" class="spend-filter-grid">
                <input type="hidden" name="month" value="{{ selectedMonthKey }}">
                <input type="hidden" name="sort" value="{{ sort }}">
                <input type="hidden" name="dir" value="{{ dir }}">

                <div class="spend-filter-field spend-filter-currency">
                    <label for="currency">{{ 'common.currency'|trans }}</label>
                    <select id="currency" name="currency">
                        <option value="">{{ 'common.all'|trans }}</option>
                        {% for code in availableCurrencies %}
                            <option value="{{ code }}" {{ code == filterCurrency ? 'selected' : '' }}>{{ code }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="spend-filter-field spend-filter-user">
                    <label for="user">{{ 'common.user'|trans }}</label>
                    <select id="user" name="user">
                        <option value="">{{ 'common.all'|trans }}</option>
                        {% for username in availableUsers %}
                            <option value="{{ username }}" {{ username == filterUser ? 'selected' : '' }}>{{ username }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="spend-filter-field spend-filter-search">
                    <label for="q">{{ 'common.search'|trans }}</label>
                    <input id="q" name="q" value="{{ filterQuery }}" placeholder="{{ 'incomes.filters.search_placeholder'|trans }}">
                </div>

                <div class="spend-filter-field spend-filter-per-page">
                    <label for="perPage">{{ 'incomes.filters.rows_per_page'|trans }}</label>
                    <select id="perPage" name="perPage">
                        {% for option in perPageOptions %}
                            <option value="{{ option }}" {{ option == perPage ? 'selected' : '' }}>{{ option }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="actions spend-filter-actions">
                    <button type="submit">{{ 'common.apply'|trans }}</button>
                    <a
                        class="btn btn-ghost"
                        href="{{ path('app_dashboard_incomes', {month: selectedMonthKey, sort: sort, dir: dir, perPage: perPage}) }}"
                    >
                        {{ 'incomes.filters.reset'|trans }}
                    </a>
                </div>
            </form>
        </section>

        {% if incomes is empty %}
            <div class="empty" style="margin-top: 14px;">
                <strong>{{ 'incomes.empty'|trans }}</strong>
            </div>
        {% else %}
            <div class="table-wrap" style="margin-top: 14px;">
                <table>
                    <thead>
                        <tr>
                            {% set nextDir = sort == 'createdAt' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'createdAt', dir: nextDir, page: 1})) }}">{{ 'common.date'|trans }}</a></th>

                            {% set nextDir = sort == 'username' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'username', dir: nextDir, page: 1})) }}">{{ 'common.user'|trans }}</a></th>

                            {% set nextDir = sort == 'amount' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'amount', dir: nextDir, page: 1})) }}">{{ 'common.amount'|trans }}</a></th>

                            {% set nextDir = sort == 'currency' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'currency', dir: nextDir, page: 1})) }}">{{ 'common.currency'|trans }}</a></th>

                            {% set nextDir = sort == 'amountInGel' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'amountInGel', dir: nextDir, page: 1})) }}">{{ 'incomes.live_gel'|trans }}</a></th>

                            {% set nextDir = sort == 'officialRatedAmountInGel' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'officialRatedAmountInGel', dir: nextDir, page: 1})) }}">{{ 'incomes.official_gel'|trans }}</a></th>

                            {% set nextDir = sort == 'rate' and dir == 'asc' ? 'desc' : 'asc' %}
                            <th><a href="{{ path('app_dashboard_incomes', query|merge({sort: 'rate', dir: nextDir, page: 1})) }}">{{ 'common.rate'|trans }}</a></th>

                            <th>{{ 'common.comment'|trans }}</th>
                            {% if is_granted('ROLE_INCOMER') %}
                                <th>{{ 'common.actions'|trans }}</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody>
                        {% for income in incomes %}
                            <tr>
                                <td>{{ income.createdAtLabel }}</td>
                                <td>{{ income.username }}</td>
                                <td>{{ income.amount }}</td>
                                <td>{{ income.currencyCode }}</td>
                                <td>{{ income.amountInGel ?? ('common.na'|trans) }}</td>
                                <td>{{ income.officialRatedAmountInGel ?? ('common.na'|trans) }}</td>
                                <td>{{ income.rate ?? ('common.na'|trans) }}</td>
                                <td>{{ income.comment ?? '-' }}</td>
                                {% if is_granted('ROLE_INCOMER') %}
                                    <td>
                                        <div class="sp-icons">
                                            <a
                                                class="icon-btn approve"
                                                href="{{ path('app_dashboard_incomes_edit', {id: income.id}) }}"
                                                title="{{ 'common.edit'|trans }}"
                                                aria-label="{{ 'common.edit'|trans }}"
                                            >
                                                <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" focusable="false">
                                                    <path d="M3 17.25V21h3.75L17.8 9.94l-3.75-3.75L3 17.25zm2.92 2.33H5v-.92l9.06-9.06.92.92L5.92 19.58zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z" fill="currentColor"></path>
                                                </svg>
                                            </a>
                                            <form method="post" action="{{ path('app_dashboard_incomes_delete', {id: income.id}) }}" onsubmit="return confirm('{{ 'income.confirm_delete'|trans }}');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_income_' ~ income.id) }}">
                                                <button type="submit" class="icon-btn delete" title="{{ 'common.delete'|trans }}" aria-label="{{ 'common.delete'|trans }}">
                                                    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" focusable="false">
                                                        <path d="M6 7h12l-1 14H7L6 7zm3-4h6l1 2h4v2H4V5h4l1-2zm1.5 6h2v9h-2V9zm4 0h2v9h-2V9z" fill="currentColor"></path>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                {% endif %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="grid metrics" style="margin-top: 14px;">
                <article class="metric">
                    <h3>{{ 'incomes.total_records'|trans }}</h3>
                    <p>{{ totalRecords }}</p>
                </article>
                <article class="metric">
                    <h3>{{ 'incomes.total_amount'|trans }}</h3>
                    <p>{{ totalAmountLabel }}</p>
                </article>
                <article class="metric">
                    <h3>{{ 'incomes.total_balance_live'|trans }}</h3>
                    <p>{{ 'common.gel_amount'|trans({'%amount%': totalAmountInGel}) }}</p>
                </article>
                <article class="metric">
                    <h3>{{ 'incomes.total_taxation_official'|trans }}</h3>
                    <p>{{ 'common.gel_amount'|trans({'%amount%': totalOfficialRatedAmountInGel}) }}</p>
                </article>
            </div>

            {% if totalPages > 1 %}
                <nav class="pagination" aria-label="{{ 'incomes.pagination'|trans }}">
                    <a
                        class="btn btn-ghost {{ page <= 1 ? 'is-disabled' : '' }}"
                        href="{{ path('app_dashboard_incomes', query|merge({page: page - 1})) }}"
                    >
                        {{ 'common.prev'|trans }}
                    </a>

                    {% for pageNo in 1..totalPages %}
                        <a
                            class="btn btn-ghost {{ pageNo == page ? 'is-active' : '' }}"
                            href="{{ path('app_dashboard_incomes', query|merge({page: pageNo})) }}"
                        >
                            {{ pageNo }}
                        </a>
                    {% endfor %}

                    <a
                        class="btn btn-ghost {{ page >= totalPages ? 'is-disabled' : '' }}"
                        href="{{ path('app_dashboard_incomes', query|merge({page: page + 1})) }}"
                    >
                        {{ 'common.next'|trans }}
                    </a>
                </nav>
            {% endif %}
        {% endif %}
    </main>

    {% if incomeForm is defined %}
        {% include 'dashboard/_income_modal.html.twig' with {incomeForm: incomeForm} %}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.dashboardIncomeFormI18n = {
            saving: {{ 'income.js.saving'|trans|json_encode|raw }},
            unableAdd: {{ 'income.js.unable_add'|trans|json_encode|raw }},
            networkError: {{ 'income.js.network_error'|trans|json_encode|raw }},
            addIncome: {{ 'dashboard.add_income_button'|trans|json_encode|raw }},
            adding: {{ 'income.js.adding'|trans|json_encode|raw }},
            added: {{ 'income.js.added'|trans|json_encode|raw }}
        };
    </script>
    <script src="{{ asset('js/dashboard-income-modal.js') }}"></script>
{% endblock %}
