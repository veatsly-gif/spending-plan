{% trans_default_domain 'messages' %}
{#
 # Standard row actions component.
 # Required: editHref, deleteAction, csrfToken, deleteConfirm
 # Optional: editTitle, deleteTitle, rowActionsClass
 #}

<div class="row-actions {{ rowActionsClass|default('') }}">
    <a
        class="row-action-btn row-action-btn--edit"
        href="{{ editHref }}"
        title="{{ editTitle|default('common.edit'|trans) }}"
        aria-label="{{ editTitle|default('common.edit'|trans) }}"
    >
        <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" focusable="false">
            <path d="M3 17.25V21h3.75L17.8 9.94l-3.75-3.75L3 17.25zm2.92 2.33H5v-.92l9.06-9.06.92.92L5.92 19.58zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z" fill="currentColor"></path>
        </svg>
    </a>
    <form method="post" action="{{ deleteAction }}" onsubmit="return confirm({{ deleteConfirm|json_encode|raw }});">
        <input type="hidden" name="_token" value="{{ csrfToken }}">
        <button
            type="submit"
            class="row-action-btn row-action-btn--delete"
            title="{{ deleteTitle|default('common.delete'|trans) }}"
            aria-label="{{ deleteTitle|default('common.delete'|trans) }}"
        >
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" focusable="false">
                <path d="M6 7h12l-1 14H7L6 7zm3-4h6l1 2h4v2H4V5h4l1-2zm1.5 6h2v9h-2V9zm4 0h2v9h-2V9z" fill="currentColor"></path>
            </svg>
        </button>
    </form>
</div>
