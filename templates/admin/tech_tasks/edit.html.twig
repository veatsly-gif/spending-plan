{% extends 'admin/admin_layout.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.tech_tasks.edit_title'|trans }}{% endblock %}

{% block admin_body %}
    <main class="panel reveal" style="max-width: 760px; margin-inline: auto;">
        <span class="kicker">{{ 'admin.tech_tasks.kicker'|trans }}</span>
        <h1>{{ 'admin.tech_tasks.edit_heading'|trans({'%title%': task.title}) }}</h1>
        {{ form_start(form) }}
            {{ form_row(form.title) }}
            {{ form_row(form.description) }}
            {{ form_row(form.status) }}
            <div class="actions">
                <button type="submit">{{ 'common.save'|trans }}</button>
                <a class="btn btn-ghost" href="{{ path('admin_tech_tasks_index') }}">{{ 'common.back'|trans }}</a>
            </div>
        {{ form_end(form) }}
    </main>
{% endblock %}
