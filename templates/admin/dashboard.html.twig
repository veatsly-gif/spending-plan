{% extends 'admin/admin_layout.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.dashboard.title'|trans }}{% endblock %}

{% block admin_body %}
    <main class="panel reveal">
        <span class="kicker">{{ 'admin.dashboard.kicker'|trans }}</span>
        <h1>{{ 'admin.dashboard.heading'|trans }}</h1>
        <p>{{ 'admin.dashboard.description'|trans }}</p>

        <section class="grid metrics">
            <article class="metric reveal delay">
                <h3>{{ 'admin.dashboard.user_management'|trans }}</h3>
                <p>{{ 'admin.dashboard.user_management_desc'|trans }}</p>
                <div class="actions">
                    <a class="btn" href="{{ path('admin_users_index') }}">{{ 'admin.dashboard.open_users'|trans }}</a>
                </div>
            </article>
            <article class="metric reveal delay">
                <h3>{{ 'admin.dashboard.telegram_approvals'|trans }}</h3>
                <p>{{ 'admin.dashboard.pending_requests'|trans({'%count%': pendingTelegramUsers})|raw }}</p>
                <div class="actions">
                    <a class="btn" href="{{ path('admin_telegram_pending') }}">{{ 'admin.dashboard.review_requests'|trans }}</a>
                </div>
            </article>
            <article class="metric reveal delay">
                <h3>{{ 'admin.dashboard.spending_plans'|trans }}</h3>
                <p>{{ 'admin.dashboard.system_plans_for_month'|trans({
                    '%month%': nextMonthLabel,
                    '%count%': nextMonthSystemSpendingPlansCount
                })|raw }}</p>
                <div class="actions">
                    <a class="btn" href="{{ path('admin_spending_plans_index') }}">{{ 'admin.dashboard.manage_plans'|trans }}</a>
                </div>
            </article>
            <article class="metric reveal delay">
                <h3>{{ 'admin.dashboard.tech_tasks'|trans }}</h3>
                <p>{{ 'admin.dashboard.tech_tasks_desc'|trans }}</p>
                <div class="actions">
                    <a class="btn" href="{{ path('admin_tech_tasks_index') }}">{{ 'admin.dashboard.open_tech_tasks'|trans }}</a>
                </div>
            </article>
        </section>

    </main>
{% endblock %}
