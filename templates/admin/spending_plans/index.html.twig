{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.spending_plans.title'|trans }}{% endblock %}

{% block body %}
    <main class="panel reveal">
        <span class="kicker">{{ 'admin.spending_plans.kicker'|trans }}</span>
        <h1>{{ 'admin.spending_plans.heading'|trans }}</h1>
        <p>{{ 'admin.spending_plans.description'|trans }}</p>

        <div class="actions">
            <a class="btn" href="{{ path('admin_spending_plans_new', {month: selectedMonthKey}) }}">{{ 'admin.spending_plans.create_plan'|trans }}</a>
        </div>

        <nav class="sp-tabs" aria-label="{{ 'admin.spending_plans.month_tabs'|trans }}">
            {% for tab in monthTabs %}
                <a
                    href="{{ path('admin_spending_plans_index', {month: tab.monthKey}) }}"
                    class="sp-tab {{ tab.active ? 'is-active' : '' }} {{ tab.needsAttention ? 'is-alert' : '' }}"
                >
                    {{ tab.label }}
                    {% if tab.needsAttention %}
                        <span class="dot">!</span>
                    {% endif %}
                </a>
            {% endfor %}
        </nav>

        <section class="sp-section">
            <h2>{{ 'admin.spending_plans.suggested_for_month'|trans({'%month%': selectedMonthLabel}) }}</h2>
            <div class="sp-list" id="sp-suggestions-list">
                {% for suggestion in suggestedPlans %}
                    <article class="sp-card suggestion-card" data-suggestion-id="{{ suggestion.id }}">
                        <header class="sp-card-head">
                            <h3>{{ suggestion.name }}</h3>
                            <span class="badge">{{ ('plan_type.' ~ suggestion.planType)|trans }}</span>
                        </header>
                        <p class="sp-meta">
                            {{ suggestion.dateFrom }} - {{ suggestion.dateTo }}
                            · {{ 'common.weight'|trans({'%value%': suggestion.weight}) }}
                        </p>
                        <div class="sp-inline-field">
                            <label for="limit-{{ suggestion.id }}">{{ 'common.limit'|trans }}</label>
                            <input
                                id="limit-{{ suggestion.id }}"
                                type="number"
                                step="0.01"
                                min="0"
                                value="{{ suggestion.limitAmount }}"
                                data-suggestion-limit
                            >
                            <select data-suggestion-currency>
                                {% for code in availableCurrencies %}
                                    <option value="{{ code }}" {{ code == suggestion.currency ? 'selected' : '' }}>
                                        {{ code }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="sp-inline-field">
                            <label for="weight-{{ suggestion.id }}">{{ 'common.weight_label'|trans }}</label>
                            <input
                                id="weight-{{ suggestion.id }}"
                                type="number"
                                step="1"
                                min="0"
                                value="{{ suggestion.weight }}"
                                data-suggestion-weight
                            >
                            <span>{{ 'common.priority'|trans }}</span>
                        </div>
                        <div class="sp-inline-field">
                            <label for="note-{{ suggestion.id }}">{{ 'common.comment'|trans }}</label>
                            <input
                                id="note-{{ suggestion.id }}"
                                type="text"
                                value="{{ suggestion.note ?? '' }}"
                                data-suggestion-note
                            >
                            <span>{{ 'common.optional'|trans }}</span>
                        </div>
                        <div class="sp-icons">
                            <button
                                type="button"
                                class="icon-btn approve"
                                title="{{ 'common.approve'|trans }}"
                                data-suggestion-approve
                            >
                                ✓
                            </button>
                            <button
                                type="button"
                                class="icon-btn delete"
                                title="{{ 'common.delete'|trans }}"
                                data-suggestion-delete
                            >
                                🗑
                            </button>
                        </div>
                    </article>
                {% else %}
                    <div class="empty" id="sp-no-suggestions">
                        <strong>{{ 'admin.spending_plans.no_suggestions'|trans }}</strong>
                    </div>
                {% endfor %}
            </div>
        </section>

        <section class="sp-section">
            <h2>{{ 'admin.spending_plans.existing_for_month'|trans({'%month%': selectedMonthLabel}) }}</h2>
            <div class="sp-list" id="sp-existing-list">
                {% for plan in existingPlans %}
                    {% include 'admin/spending_plans/_existing_card.html.twig' with {plan: plan} %}
                {% else %}
                    <div class="empty" id="sp-no-existing">
                        <strong>{{ 'admin.spending_plans.no_existing'|trans }}</strong>
                    </div>
                {% endfor %}
            </div>
        </section>

    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.spendingPlansPage = {
            month: {{ selectedMonthKey|json_encode|raw }},
            approveUrlTemplate: {{ path(
                'admin_spending_plans_suggestion_approve',
                {month: 'MONTH', suggestionId: 'ID'}
            )|json_encode|raw }},
            deleteUrlTemplate: {{ path(
                'admin_spending_plans_suggestion_delete',
                {month: 'MONTH', suggestionId: 'ID'}
            )|json_encode|raw }},
            csrfToken: {{ csrf_token('sp_suggestion_action')|json_encode|raw }},
            i18n: {
                unableApprove: {{ 'admin.spending_plans.unable_approve'|trans|json_encode|raw }},
                unableDelete: {{ 'admin.spending_plans.unable_delete'|trans|json_encode|raw }},
                toastApproved: {{ 'admin.spending_plans.approved'|trans|json_encode|raw }},
                toastDeleted: {{ 'admin.spending_plans.deleted'|trans|json_encode|raw }},
                noSuggestions: {{ 'admin.spending_plans.no_suggestions'|trans|json_encode|raw }}
            }
        };
    </script>
    <script src="{{ asset('js/spending-plans.js') }}"></script>
{% endblock %}
