{% extends 'base.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.users.index_title'|trans }}{% endblock %}

{% block body %}
    <main class="panel reveal">
        <span class="kicker">{{ 'admin.users.kicker'|trans }}</span>
        <h1>{{ 'admin.users.heading'|trans }}</h1>
        <div class="actions">
            <a class="btn" href="{{ path('admin_users_new') }}">{{ 'admin.users.create_user'|trans }}</a>
        </div>

        <section class="table-wrap reveal delay">
            <table>
                <thead>
                    <tr>
                        <th>{{ 'common.id'|trans }}</th>
                        <th>{{ 'common.username'|trans }}</th>
                        <th>{{ 'common.roles'|trans }}</th>
                        <th>{{ 'common.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>{{ user.id }}</td>
                            <td>{{ user.username }}</td>
                            <td>{{ user.roles|join(', ') }}</td>
                            <td>
                                <div class="actions">
                                    <a class="btn btn-ghost" href="{{ path('admin_users_edit', {id: user.id}) }}">{{ 'common.edit'|trans }}</a>
                                    <a class="btn btn-ghost" href="{{ path('admin_users_password', {id: user.id}) }}">{{ 'common.password'|trans }}</a>
                                    <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" style="display:inline;" onsubmit="return confirm('{{ 'admin.users.confirm_delete'|trans({'%username%': user.username})|e('js') }}');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                        <button type="submit" class="btn-danger">{{ 'common.delete'|trans }}</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4">
                                <div class="empty">
                                    <strong>{{ 'admin.users.no_users'|trans }}</strong>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </main>
{% endblock %}
