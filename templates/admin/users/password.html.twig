{% extends 'admin/admin_layout.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.users.password_title'|trans }}{% endblock %}

{% block admin_body %}
    <main class="panel reveal">
        <div class="panel-head-inline">
            <div>
            <div class="actions">
                <a class="btn btn-ghost" href="{{ path('admin_users_index') }}">{{ 'common.back'|trans }}</a>
            </div>
        </div>

        {{ form_start(form, {attr: {class: 'compact-form'}}) }}
            <div class="form-grid">
                <div class="form-col">
                    {{ form_row(form.plainPassword.first) }}
                </div>
                <div class="form-col">
                    {{ form_row(form.plainPassword.second) }}
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn">{{ 'admin.users.update_password'|trans }}</button>
                <a class="btn btn-ghost" href="{{ path('admin_users_index') }}">{{ 'common.cancel'|trans }}</a>
            </div>
{% block stylesheets %}
    {{ parent() }}
    <style>
        .compact-form .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 16px;
        }

        .compact-form input {
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
        }

        .compact-form .actions {
            margin-top: 24px;
            padding-top: 16px;
            border-top: 1px solid var(--line);
        }

        @media (max-width: 768px) {
            .compact-form .form-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
        }
    </style>
{% endblock %}
                <button type="submit">{{ 'admin.users.update_password'|trans }}</button>
                <a class="btn btn-ghost" href="{{ path('admin_users_index') }}">{{ 'common.back'|trans }}</a>
            </div>
        {{ form_end(form) }}
    </main>
{% endblock %}
