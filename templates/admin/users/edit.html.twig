{% extends 'admin/admin_layout.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.users.edit_title'|trans }}{% endblock %}

{% block admin_body %}
    <main class="panel reveal">
        <div class="panel-head-inline">
            <div>
        <span class="kicker">{{ 'admin.users.management_kicker'|trans }}</span>
        <h1>{{ 'admin.users.edit_heading'|trans({'%username%': userEntity.username}) }}</h1>
            </div>
            <div class="actions">
                <a class="btn btn-ghost" href="{{ path('admin_users_index') }}">{{ 'common.back'|trans }}</a>
            </div>
        </div>

        {{ form_start(form, {attr: {class: 'compact-form'}}) }}
            <div class="form-grid">
                <div class="form-col">
                    {{ form_row(form.username) }}
                </div>
                <div class="form-col">
                    {{ form_row(form.roles) }}
                </div>
            </div>

            <div class="actions">
                <button type="submit" class="btn">{{ 'common.save'|trans }}</button>
                <a class="btn btn-ghost" href="{{ path('admin_users_index') }}">{{ 'common.cancel'|trans }}</a>
            </div>
        {{ form_end(form) }}
    </main>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .compact-form .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 16px;
        }

        .compact-form input,
        .compact-form select {
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
        }

        .compact-form .actions {
            margin-top: 24px;
            padding-top: 16px;
            border-top: 1px solid var(--line);
        }

        @media (max-width: 768px) {
            .compact-form .form-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }
        }
    </style>
{% endblock %}
