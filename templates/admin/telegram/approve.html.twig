{% extends 'admin/admin_layout.html.twig' %}
{% trans_default_domain 'messages' %}

{% block title %}{{ 'admin.telegram.approve_title'|trans }}{% endblock %}

{% block admin_body %}
    <main class="panel reveal" style="max-width: 680px; margin-inline: auto;">
        <span class="kicker">{{ 'admin.telegram.approval_kicker'|trans }}</span>
        <h1>{{ 'admin.telegram.approve_heading'|trans }}</h1>
        <p>
            {{ 'admin.telegram.telegram_user'|trans }}: <strong>{{ telegramUser.firstName }} {{ telegramUser.lastName ?? '' }}</strong>
            ({{ telegramUser.telegramId }})
        </p>

        {{ form_start(approveForm) }}
            {{ form_row(approveForm.user) }}
            <div class="actions">
                <button type="submit">{{ 'admin.telegram.approve_and_link'|trans }}</button>
                <a class="btn btn-ghost" href="{{ path('admin_telegram_pending') }}">{{ 'common.back'|trans }}</a>
            </div>
        {{ form_end(approveForm) }}
    </main>
{% endblock %}
