APP_ENV=dev
APP_DEBUG=1
APP_SECRET=replace-with-local-secret
APP_SHARE_DIR=var/share

DEFAULT_URI=http://localhost:8188

POSTGRES_DB=spending_plan
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_TEST_DB=spending_plan_test
POSTGRES_TEST_USER=app_test
POSTGRES_TEST_PASSWORD=app_test

DATABASE_URL="postgresql://app:app@postgres:5432/spending_plan?serverVersion=16&charset=utf8"
TEST_DATABASE_URL="postgresql://app_test:app_test@postgres_test:5432/spending_plan_test?serverVersion=16&charset=utf8"

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PUBLIC_HOST=
