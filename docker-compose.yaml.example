services:
  php:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
      target: dev
    container_name: spending_plan_php
    working_dir: /var/www/app
    volumes:
      - ./:/var/www/app
      - ./var/ssh-key/spending-plan-prod:/run/secrets/prod_ssh_key:ro
    environment:
      APP_ENV: ${APP_ENV:-dev}
      APP_DEBUG: ${APP_DEBUG:-1}
      XDEBUG_MODE: ${XDEBUG_MODE:-off}
      XDEBUG_CLIENT_HOST: ${XDEBUG_CLIENT_HOST:-host.docker.internal}
      XDEBUG_CLIENT_PORT: ${XDEBUG_CLIENT_PORT:-9003}
      XDEBUG_IDEKEY: ${XDEBUG_IDEKEY:-PHPSTORM}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started

  nginx:
    image: nginx:1.27-alpine
    container_name: spending_plan_nginx
    depends_on:
      - php
    ports:
      - "8188:80"
    volumes:
      - ./:/var/www/app:ro
      - ./docker/nginx/conf.d/default.conf:/etc/nginx/conf.d/default.conf:ro

  node:
    profiles:
      - frontend
    image: node:22-alpine
    container_name: spending_plan_node
    working_dir: /var/www/app/frontend
    volumes:
      - ./:/var/www/app
    ports:
      - "5173:5173"
    environment:
      - NODE_ENV=development
      - VITE_BACKEND_URL=${VITE_BACKEND_URL:-http://localhost:8188}
      - VITE_API_BASE_URL=${VITE_API_BASE_URL:-/api}
    command: sh -c "npm install && npm run dev -- --host 0.0.0.0 --port 5173"
    stdin_open: true
    tty: true

  postgres:
    image: postgres:16-alpine
    container_name: spending_plan_postgres
    environment:
      POSTGRES_DB: ${POSTGRES_DB}
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  postgres_test:
    profiles:
      - test
    image: postgres:16-alpine
    container_name: spending_plan_postgres_test
    environment:
      POSTGRES_DB: ${POSTGRES_TEST_DB:-spending_plan_test}
      POSTGRES_USER: ${POSTGRES_TEST_USER:-app_test}
      POSTGRES_PASSWORD: ${POSTGRES_TEST_PASSWORD:-app_test}
    ports:
      - "5433:5432"
    volumes:
      - postgres_test_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_TEST_USER:-app_test} -d ${POSTGRES_TEST_DB:-spending_plan_test}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  redis:
    image: redis:7-alpine
    container_name: spending_plan_redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data

volumes:
  postgres_data:
  postgres_test_data:
  redis_data:
