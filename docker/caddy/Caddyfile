# Production only: set PUBLIC_HOST in the server .env (hostname without scheme, no trailing slash).
# Caddy requests a free certificate from Let's Encrypt (ACME HTTP-01 on port 80).
# Do not commit real hostnames here; keep them in .env on the VPS.

{$PUBLIC_HOST} {
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	encode gzip
	reverse_proxy nginx:80
}
